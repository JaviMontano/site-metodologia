rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // === RBAC Helper Functions (v2) ===

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return request.auth.token.role;
    }

    function isSuperAdmin() {
      return getUserRole() == 'super_admin';
    }

    function isAdminOrAbove() {
      return getUserRole() in ['super_admin', 'admin'];
    }

    function isEditorOrAbove() {
      return getUserRole() in ['super_admin', 'admin', 'editor'];
    }

    function hasAnyRole() {
      return getUserRole() != null;
    }

    // Legacy backward compatibility (remove after migration)
    function isLegacyAdmin() {
      return request.auth.token.admin == true;
    }

    function hasWriteAccess() {
      return isEditorOrAbove() || isLegacyAdmin();
    }

    function hasAdminAccess() {
      return isAdminOrAbove() || isLegacyAdmin();
    }

    // Schema validation helpers
    function hasString(field) {
      return field is string && field.size() > 0;
    }

    function hasStringArray(field) {
      return field is list && field.size() > 0;
    }

    // Allowed self-update fields for users
    function isAllowedSelfUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['display_name', 'preferred_language', 'updated_at', 'last_login', 'total_sessions']);
    }

    // === Collection Rules ===

    // Programs — public read, editor+ write with schema validation
    match /programs/{programId} {
      allow read: if true;
      allow create, update: if hasWriteAccess()
        && hasString(request.resource.data.audience)
        && request.resource.data.audience in ['empresas', 'personas']
        && hasString(request.resource.data.slug)
        && request.resource.data.sort_order is int
        && request.resource.data.sort_order >= 0
        && hasString(request.resource.data.title_es)
        && hasString(request.resource.data.title_en)
        && hasString(request.resource.data.description_es)
        && hasString(request.resource.data.description_en)
        && hasStringArray(request.resource.data.benefits_es)
        && hasStringArray(request.resource.data.benefits_en)
        && hasString(request.resource.data.transformation_es)
        && hasString(request.resource.data.transformation_en)
        && request.resource.data.is_published is bool
        && request.resource.data.updated_at is timestamp
        && hasString(request.resource.data.updated_by);
      allow delete: if hasAdminAccess();
    }

    // Pricing — public read, editor+ write
    match /pricing/{category} {
      allow read: if true;
      allow write: if hasWriteAccess()
        && request.resource.data.updated_at is timestamp
        && hasString(request.resource.data.updated_by);
    }

    // Translations — public read, editor+ write
    match /translations/{lang} {
      allow read: if true;
      allow write: if hasWriteAccess()
        && request.resource.data.keys().hasAny(['_meta'])
        && request.resource.data._meta.updated_at is timestamp
        && hasString(request.resource.data._meta.updated_by);
    }

    // Users — role-gated access
    match /users/{uid} {
      // Read own doc: any authenticated user
      allow read: if isAuthenticated() && request.auth.uid == uid;
      // Read all users: super_admin only
      allow list: if isSuperAdmin();
      // Create: NEVER via client (only Cloud Function)
      allow create: if false;
      // Update own profile fields only
      allow update: if isAuthenticated()
        && request.auth.uid == uid
        && isAllowedSelfUpdate();
      // Delete: NEVER
      allow delete: if false;
    }

    // Config — access control and settings
    match /config/{docId} {
      allow read: if docId == 'settings' || (isAuthenticated() && hasAnyRole());
      allow write: if isSuperAdmin();
    }

    // Config invites — super_admin only
    match /config/invites/{hash} {
      allow read: if isSuperAdmin();
      allow create: if false; // Only Cloud Function creates
      allow delete: if isSuperAdmin();
      allow update: if false;
    }

    // Audit log — admin+ read, editor+ create, immutable
    match /audit_log/{entryId} {
      allow read: if hasAdminAccess();
      allow create: if hasWriteAccess();
      allow update, delete: if false;
    }

    // Page overrides — editor+ read/write, admin+ delete
    match /page_overrides/{pathHash} {
      allow read: if hasWriteAccess();
      allow create, update: if hasWriteAccess();
      allow delete: if hasAdminAccess();
    }

    // === Phase 1: New Collections (Feature 008) ===

    // Resources — public read, editor+ write with schema validation
    match /resources/{resourceId} {
      allow read: if true;
      allow create, update: if hasWriteAccess()
        && hasString(request.resource.data.slug)
        && hasString(request.resource.data.category_id)
        && hasString(request.resource.data.title_es)
        && hasString(request.resource.data.title_en)
        && hasString(request.resource.data.description_es)
        && hasString(request.resource.data.description_en)
        && request.resource.data.type in [
          'biblioteca', 'miniapp', 'ebook', 'playbook', 'asistente',
          'workflow', 'prototipo', 'plugin', 'flujo', 'catalogo', 'a-medida'
        ]
        && hasString(request.resource.data.url_path)
        && request.resource.data.is_premium is bool
        && request.resource.data.is_published is bool
        && request.resource.data.sort_order is int
        && request.resource.data.sort_order >= 0
        && request.resource.data.updated_at is timestamp
        && hasString(request.resource.data.updated_by);
      allow delete: if hasAdminAccess();
    }

    // Resource categories — public read, editor+ write
    match /resource_categories/{categoryId} {
      allow read: if true;
      allow create, update: if hasWriteAccess()
        && hasString(request.resource.data.slug)
        && hasString(request.resource.data.name_es)
        && hasString(request.resource.data.name_en)
        && hasString(request.resource.data.description_es)
        && hasString(request.resource.data.description_en)
        && request.resource.data.sort_order is int
        && request.resource.data.sort_order >= 0
        && request.resource.data.is_published is bool
        && request.resource.data.updated_at is timestamp
        && hasString(request.resource.data.updated_by);
      allow delete: if hasAdminAccess();
    }

    // Page content — public read, editor+ write
    match /page_content/{pathHash} {
      allow read: if true;
      allow create, update: if hasWriteAccess()
        && hasString(request.resource.data.path)
        && request.resource.data.meta.keys().hasAny(['title_es', 'title_en'])
        && hasString(request.resource.data.meta.title_es)
        && hasString(request.resource.data.meta.title_en)
        && request.resource.data.is_migrated is bool
        && request.resource.data.updated_at is timestamp
        && hasString(request.resource.data.updated_by);
      allow delete: if hasAdminAccess();
    }

    // Curriculum — public read, editor+ write
    match /curriculum/{curriculumId} {
      allow read: if true;
      allow create, update: if hasWriteAccess()
        && request.resource.data.audience in ['empresas', 'personas']
        && hasString(request.resource.data.program_slug)
        && request.resource.data.modules is list
        && request.resource.data.total_hours is number
        && request.resource.data.is_published is bool
        && request.resource.data.updated_at is timestamp
        && hasString(request.resource.data.updated_by);
      allow delete: if hasAdminAccess();
    }

    // Site config — public read, super_admin only write
    match /site_config/{configId} {
      allow read: if true;
      allow create, update, delete: if isSuperAdmin()
        && request.resource.data.updated_at is timestamp
        && hasString(request.resource.data.updated_by);
    }
  }
}
